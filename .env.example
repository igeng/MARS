# ============================================================
# MARS - Multi-Agent Research System
# Environment Variables Configuration
# Copy this file to .env and fill in your API keys
# ============================================================

# ---- LLM Provider API Keys ----

# Alibaba Cloud DashScope (Qwen models)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Moonshot AI (Kimi)
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Zhipu AI (GLM)
ZHIPU_API_KEY=your_zhipu_api_key_here

# ---- Academic Search APIs ----

# Semantic Scholar API (optional, increases rate limits)
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# ---- Default LLM Settings ----

# Default provider: qwen | deepseek | kimi | glm
DEFAULT_LLM_PROVIDER=qwen

# Default model per provider (uncomment and set if you want to override defaults)
# QWEN_MODEL=qwen-max
# DEEPSEEK_MODEL=deepseek-chat
# KIMI_MODEL=moonshot-v1-8k
# GLM_MODEL=glm-4-plus

# ---- Application Settings ----

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Maximum number of papers to retrieve per search
MAX_PAPERS_PER_SEARCH=50

# Number of papers for deep analysis
MAX_PAPERS_FOR_ANALYSIS=20

# Output directory for reports and cached results
OUTPUT_DIR=./output
