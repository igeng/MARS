# ============================================================
# MARS - Multi-Agent Research System
# Environment Variables Configuration
# Copy this file to .env and fill in your API keys
# ============================================================

# ---- LLM Provider API Key ----

# DeepSeek (required)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ---- Academic Search APIs ----

# Semantic Scholar API (optional, increases rate limits)
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# ---- LLM Settings ----

# Default model
# DEEPSEEK_MODEL=deepseek-v4-flash

# ---- Application Settings ----

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Maximum number of papers to retrieve per search
MAX_PAPERS_PER_SEARCH=50

# Number of papers for deep analysis
MAX_PAPERS_FOR_ANALYSIS=20

# Number of papers in initial wide search pool (before LLM reranking)
# SEARCH_POOL_SIZE=200

# HTTP read timeout (seconds) for arXiv API requests
# ARXIV_SEARCH_TIMEOUT=30

# Output directory for reports and cached results
OUTPUT_DIR=./output

# Max tool-call iterations per agent
# AGENT_MAX_ITER=10

# Retrieval mode: "online" (live APIs) or "surge" (SurGE corpus)
# CORPUS_MODE=online

# ---- Database ----

# SQLAlchemy database URL (default: SQLite)
DATABASE_URL=sqlite:///./mars.db

# ---- API Server ----

# Host and port for the FastAPI server (mars api)
API_HOST=0.0.0.0
API_PORT=8000
